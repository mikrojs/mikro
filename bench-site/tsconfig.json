{
  "extends": "../tsconfig.json",
  "include": ["src/**/*.ts"],
  "compilerOptions": {
    "types": ["node"],
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true
  }
}
