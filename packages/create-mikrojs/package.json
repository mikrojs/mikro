{
  "name": "create-mikrojs",
  "version": "0.0.0",
  "description": "Create a new Mikro.js project",
  "keywords": [
    "esp32",
    "javascript",
    "microcontroller",
    "mikrojs",
    "quickjs",
    "typescript"
  ],
  "homepage": "https://github.com/mikrojs/mikrojs#readme",
  "bugs": {
    "url": "https://github.com/mikrojs/mikrojs/issues"
  },
  "license": "MIT",
  "author": "Bjørge Næss <bjoerge@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikrojs/mikrojs.git"
  },
  "bin": {
    "create-mikrojs": "bin/create-mikrojs.js"
  },
  "files": [
    "dist",
    "src/templates",
    "bin"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.js"
    }
  },
  "scripts": {
    "build:ts": "tsc -p tsconfig.build.json",
    "inspect": "tsx src/inspect.ts",
    "prepublishOnly": "tsc -p tsconfig.build.json",
    "publint": "publint",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@optique/core": "^0.10.7",
    "@optique/run": "^0.10.7",
    "type-fest": "^5.5.0"
  },
  "devDependencies": {
    "@types/node": "catalog:node24",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
