{
  "extends": "./tsconfig.json",
  "include": ["runtime.d.ts", "src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["src/**/__test__/**", "src/**/*.test.ts", "src/**/*.test.tsx"],
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "rootDir": "src",
    "outDir": "dist"
  }
}
