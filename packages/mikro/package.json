  "scripts": {
    "build:ts": "tsc -p tsconfig.build.json",
    "publint": "publint",
    "test:device": "DEVICE_TEST=1 vitest run src/cli/lib/__test__/protocol-device.test.ts",
    "typecheck": "tsc --noEmit",
    "watch": "tsc -p tsconfig.build.json --watch --preserveWatchOutput"
