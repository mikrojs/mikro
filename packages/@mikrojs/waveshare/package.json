{
  "name": "@mikrojs/waveshare",
  "version": "0.0.0",
  "private": true,
  "description": "Waveshare board definitions for Mikro.js",
  "license": "MIT",
  "type": "module",
  "exports": {
    "./cmake": "./cmake.js",
    "./esp32-s3-knob-touch-lcd-1.8": "./boards/esp32-s3-knob-touch-lcd-1.8/esp32-s3-knob-touch-lcd-1.8.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@mikrojs/driver-sh8601": "workspace:*"
  },
  "engines": {
    "mikrojs": ">=0.0.0"
  },
  "mikrojs": {
    "boards": {
      "./esp32-s3-knob-touch-lcd-1.8": {
        "chip": "esp32s3",
        "runtime": "./boards/esp32-s3-knob-touch-lcd-1.8/esp32-s3-knob-touch-lcd-1.8.ts",
        "sdkconfig": "./boards/esp32-s3-knob-touch-lcd-1.8/sdkconfig.defaults",
        "description": "1.8\" round touch LCD with rotary encoder"
      }
    }
  }
}
