{
  "name": "@mikrojs/lilygo",
  "version": "0.0.0",
  "private": true,
  "description": "LilyGo board definitions for Mikro.js",
  "license": "MIT",
  "type": "module",
  "exports": {
    "./t-display": {
      "import": "./dist/t-display.js",
      "development": "./src/t-display.ts"
    }
  },
  "publishConfig": {
    "exports": {
      "./t-display": "./dist/t-display.js",
      "./package.json": "./package.json"
    }
  },
  "scripts": {
    "build:ts": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "watch": "tsc -p tsconfig.build.json --watch --preserveWatchOutput"
  },
  "dependencies": {
    "@mikrojs/driver-st7789": "workspace:*"
  },
  "engines": {
    "mikrojs": ">=0.0.0"
  },
  "mikrojs": {
    "boards": {
      "./t-display": {
        "chip": "esp32",
        "runtime": "./dist/t-display.js",
        "description": "1.14\" IPS TFT (135x240) with two buttons"
      }
    }
  }
}
