{
  "name": "@mikrojs/eslint-plugin",
  "version": "0.0.6",
  "description": "ESLint plugin for Mikro.js projects",
  "keywords": [
    "eslint",
    "eslint-plugin",
    "mikrojs"
  ],
  "homepage": "https://github.com/mikrojs/mikrojs#readme",
  "bugs": {
    "url": "https://github.com/mikrojs/mikrojs/issues"
  },
  "license": "MIT",
  "author": "Bjørge Næss <bjoerge@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikrojs/mikrojs.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "exports": {
      ".": "./dist/index.js"
    }
  },
  "scripts": {
    "build:ts": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@typescript-eslint/utils": "^8.59.0",
    "typescript-eslint": "catalog:"
  },
  "devDependencies": {
    "@typescript-eslint/rule-tester": "^8.59.0",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "eslint": "^10.0.0",
    "typescript": "^6.0.0"
  }
}
