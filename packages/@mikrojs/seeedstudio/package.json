{
  "name": "@mikrojs/seeedstudio",
  "version": "0.0.0",
  "private": true,
  "description": "Seeed Studio board definitions for Mikro.js",
  "license": "MIT",
  "type": "module",
  "exports": {
    "./xiao-esp32c6": "./src/xiao-esp32c6.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "mikrojs": ">=0.0.0"
  },
  "mikrojs": {
    "boards": {
      "./xiao-esp32c6": {
        "chip": "esp32c6",
        "runtime": "./src/xiao-esp32c6.ts",
        "description": "XIAO ESP32-C6 development board"
      }
    }
  }
}
