{
  "name": "@mikrojs/firmware",
  "version": "0.0.1",
  "description": "Mikro.js ESP32 firmware: ESP-IDF component, build tools, and project template",
  "keywords": [
    "esp-idf",
    "esp32",
    "firmware",
    "mikrojs"
  ],
  "homepage": "https://github.com/mikrojs/mikrojs#readme",
  "bugs": {
    "url": "https://github.com/mikrojs/mikrojs/issues"
  },
  "license": "MIT",
  "author": "Bjørge Næss <bjoerge@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikrojs/mikrojs.git"
  },
  "bin": {
    "idf.py": "./bin/idf.py"
  },
  "files": [
    "components",
    "default-app",
    "prebuilds",
    "sdkconfig.defaults",
    "sdkconfig.defaults.*",
    "partitions.csv",
    "bin",
    "chips.json",
    "cmake.js",
    "discover.js",
    "index.js",
    "index.d.ts",
    "project.cmake",
    "resolve.js"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./cmake": "./cmake.js",
    "./discover": "./discover.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "prepublishOnly": "node scripts/verify-prebuilds.js"
  },
  "dependencies": {
    "@mikrojs/native": "workspace:*",
    "@mikrojs/quickjs": "workspace:*",
    "esbuild": "^0.28.0"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
