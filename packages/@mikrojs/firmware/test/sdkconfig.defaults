# --- Task & stack sizes ---
CONFIG_ESP_MAIN_TASK_STACK_SIZE=16384
CONFIG_ESP_SYSTEM_EVENT_TASK_STACK_SIZE=4096
CONFIG_ESP_MINIMAL_SHARED_STACK_SIZE=2048

# --- Partition table ---
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="littlefs_partition.csv"

# --- Flash ---
# Test partition layout needs > 2MB (factory 0x1E0000 + littlefs 0x30000 + header).
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="4MB"
CONFIG_ESPTOOLPY_FLASHFREQ="80m"

# --- RAM optimization ---
CONFIG_COMPILER_OPTIMIZATION_SIZE=y
CONFIG_HEAP_PLACE_FUNCTION_INTO_FLASH=y
CONFIG_FREERTOS_PLACE_FUNCTIONS_INTO_FLASH=y
CONFIG_RINGBUF_PLACE_FUNCTIONS_INTO_FLASH=y
CONFIG_ESP_WIFI_IRAM_OPT=n
CONFIG_ESP_WIFI_RX_IRAM_OPT=n
CONFIG_SPI_MASTER_ISR_IN_IRAM=n
CONFIG_ESP_EVENT_POST_FROM_IRAM_ISR=n
CONFIG_UART_ISR_IN_IRAM=y

# --- Logging ---
CONFIG_LOG_DEFAULT_LEVEL=1
CONFIG_LOG_MAXIMUM_LEVEL=3
CONFIG_LOG_DYNAMIC_LEVEL_CONTROL=n
CONFIG_LOG_IN_IRAM=n
CONFIG_BOOTLOADER_LOG_LEVEL=1

# --- Binary size ---
CONFIG_BT_ENABLED=n
CONFIG_COMPILER_CXX_EXCEPTIONS=n
CONFIG_COMPILER_CXX_RTTI=n
CONFIG_VFS_SUPPORT_SELECT=n
CONFIG_COMPILER_OPTIMIZATION_CHECKS_SILENT=y
CONFIG_ESP_ERR_TO_NAME_LOOKUP=n
CONFIG_HAL_DEFAULT_ASSERTION_LEVEL=0
# IPv6 on so the UDP native module compiles (AF_INET6 / sockaddr_in6
# come from lwIP headers gated on LWIP_IPV6).
CONFIG_LWIP_IPV6=y

# --- Test-specific ---
CONFIG_ESP_TASK_WDT_EN=n
CONFIG_UNITY_ENABLE_COLOR=y
