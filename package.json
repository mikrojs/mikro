{
  "name": "mikrojs-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Mikro.js workspace",
  "homepage": "https://github.com/mikrojs/mikrojs#readme",
  "bugs": {
    "url": "https://github.com/mikrojs/mikrojs/issues"
  },
  "license": "MIT",
  "author": "Bjørge Næss <bjoerge@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mikrojs/mikrojs.git"
  },
  "files": [],
  "type": "module",
  "scripts": {
    "bench": "pnpm -r run bench",
    "bench:dev": "pnpm --filter @repo/bench-site dev",
    "build": "run-s build:cpp build:ts build:docs",
    "build:cpp": "run-p build:lib build:native",
    "build:docs": "pnpm --filter @repo/docs build",
    "build:lib": "cmake -B packages/@mikrojs/native/build packages/@mikrojs/native && cmake --build packages/@mikrojs/native/build",
    "build:native": "pnpm --filter @mikrojs/native build:native",
    "build:ts": "pnpm -r --if-present run build:ts",
    "build:watch": "pnpm -r --parallel --if-present run build:watch",
    "check": "run-s build:cpp build:ts check:lint test",
    "check:lint": "run-p typecheck lint fmt:check knip",
    "clean": "run-p clean:*",
    "clean:dist": "pnpm -r exec rm -rf dist",
    "clean:examples": "pnpm --filter './examples/*' exec rm -rf build",
    "clean:lib": "rm -rf packages/@mikrojs/native/build",
    "clean:native": "pnpm --filter @mikrojs/native clean",
    "clean:qjsc": "rm -rf packages/@mikrojs/quickjs/bin",
    "dev": "pnpm -r --parallel --if-present run watch",
    "docs:build": "pnpm --filter @repo/docs build",
    "docs:dev": "pnpm --filter @repo/docs dev",
    "docs:preview": "pnpm --filter @repo/docs preview",
    "firmware:build": "pnpm --filter @mikrojs/firmware-dev build",
    "firmware:flash": "pnpm --filter @mikrojs/firmware-dev flash",
    "firmware:test": "pnpm --filter @mikrojs/firmware-dev test",
    "flash": "mikro flash",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "knip": "knip",
    "lint": "eslint",
    "precommit": "run-p lint fmt:check",
    "prepare": "lefthook install",
    "publint": "pnpm -r run publint",
    "test": "run-p test:*",
    "test:js": "vitest run",
    "test:lib": "cmake -B packages/@mikrojs/native/build -DBUILD_TESTING=ON packages/@mikrojs/native && cmake --build packages/@mikrojs/native/build && ctest --test-dir packages/@mikrojs/native/build --output-on-failure",
    "typecheck": "pnpm -r --if-present run typecheck",
    "watch": "pnpm dev"
  },
  "devDependencies": {
    "@mikrojs/eslint-plugin": "workspace:*",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "catalog:",
    "eslint-plugin-import": "catalog:",
    "eslint-plugin-package-json": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "eslint-plugin-simple-import-sort": "catalog:",
    "knip": "^6.6.2",
    "lefthook": "^2.1.6",
    "mikrojs": "workspace:*",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.46.0",
    "publint": "^0.3.18",
    "taze": "^19.11.0",
    "tsx": "^4.21.0",
    "typescript": "catalog:",
    "unbarrelify": "^1.1.1",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.33.2"
}
