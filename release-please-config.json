{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "node",
  "include-component-in-tag": true,
  "include-v-in-tag": false,
  "tag-separator": "@",
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": true,
  "packages": {
    "packages/mikrojs": {"component": "mikrojs", "release-as": "0.1.0"},
    "packages/@mikrojs/native": {"component": "@mikrojs/native", "release-as": "0.1.0"},
    "packages/@mikrojs/quickjs": {"component": "@mikrojs/quickjs", "release-as": "0.1.0"},
    "packages/@mikrojs/firmware": {"component": "@mikrojs/firmware", "release-as": "0.1.0"},
    "packages/@mikrojs/analyze-imports": {
      "component": "@mikrojs/analyze-imports",
      "release-as": "0.1.0"
    },
    "packages/@mikrojs/esptool": {"component": "@mikrojs/esptool", "release-as": "0.1.0"},
    "packages/@mikrojs/eslint-plugin": {
      "component": "@mikrojs/eslint-plugin",
      "release-as": "0.1.0"
    },
    "packages/create-mikrojs": {"component": "create-mikrojs", "release-as": "0.1.0"},
    "packages/create-mikro": {"component": "create-mikro", "release-as": "0.1.0"}
  },
  "plugins": [
    {
      "type": "linked-versions",
      "groupName": "core",
      "components": ["mikrojs", "@mikrojs/native", "@mikrojs/quickjs", "@mikrojs/firmware"]
    },
    {
      "type": "linked-versions",
      "groupName": "create",
      "components": ["create-mikrojs", "create-mikro"]
    }
  ]
}
