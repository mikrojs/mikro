PATH_add "$(pwd)/node_modules/.bin:$PATH"
# Resolve workspace package imports to .ts source (via "development" export condition)
# and run .ts files directly via tsx, so no build step is needed during development.
# Only set after pnpm install (tsx must be available for --import to work).
if node -e "import('tsx')" 2>/dev/null; then
    export NODE_OPTIONS="--conditions development --import tsx/esm"
fi
